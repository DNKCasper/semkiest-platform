{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@semkiest/shared-types": ["packages/shared-types/src"],
      "@semkiest/shared-types/*": ["packages/shared-types/src/*"],
      "@semkiest/shared-utils": ["packages/shared-utils/src"],
      "@semkiest/shared-utils/*": ["packages/shared-utils/src/*"],
      "@semkiest/shared-config": ["packages/shared-config/src"],
      "@semkiest/shared-config/*": ["packages/shared-config/src/*"],
      "@semkiest/db": ["packages/db/src"],
      "@semkiest/db/*": ["packages/db/src/*"]
    }
  },
  "references": [
    { "path": "packages/shared-config" },
    { "path": "packages/shared-types" },
    { "path": "packages/shared-utils" },
    { "path": "packages/db" },
    { "path": "apps/web" },
    { "path": "apps/api" },
    { "path": "apps/worker" }
  ],
  "exclude": ["node_modules"]
}
