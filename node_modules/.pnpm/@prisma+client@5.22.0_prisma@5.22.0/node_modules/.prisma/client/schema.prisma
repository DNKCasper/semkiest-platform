// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Uncomment directUrl when using a connection pooler (e.g., PgBouncer)
  // directUrl = env("DIRECT_URL")
}

// ============================================================
// Organization — top-level tenant owning users, projects, and
// agent configurations.
// ============================================================
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users        User[]
  projects     Project[]
  agentConfigs AgentConfig[]
  aiCredits    AiCreditUsage[]

  @@map("organizations")
}

// ============================================================
// User — member of an organization, with a defined role.
// ============================================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  orgId        String   @map("org_id")
  role         UserRole @default(VIEWER)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([orgId])
  @@map("users")
}

// ============================================================
// Project — a unit of work within an organization, containing
// test profiles and test runs.
// ============================================================
model Project {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  testProfiles TestProfile[]
  baselines    Baseline[]

  @@index([orgId])
  @@map("projects")
}

// ============================================================
// TestProfile — named configuration (browser, viewport, env)
// defining how tests are executed within a project.
// ============================================================
model TestProfile {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  /// JSON configuration for the test profile (browser, viewport, environment, etc.)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns TestRun[]

  @@index([projectId])
  @@map("test_profiles")
}

// ============================================================
// TestRun — a single execution of a test profile, capturing
// overall run status and timing.
// ============================================================
model TestRun {
  id            String        @id @default(cuid())
  testProfileId String        @map("test_profile_id")
  status        TestRunStatus @default(PENDING)
  startedAt     DateTime?     @map("started_at")
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  testProfile TestProfile  @relation(fields: [testProfileId], references: [id], onDelete: Cascade)
  testResults TestResult[]

  @@index([testProfileId])
  @@index([status])
  @@map("test_runs")
}

// ============================================================
// TestResult — outcome of a single test case within a run.
// ============================================================
model TestResult {
  id           String           @id @default(cuid())
  testRunId    String           @map("test_run_id")
  testName     String           @map("test_name")
  status       TestResultStatus @default(PENDING)
  errorMessage String?          @map("error_message")
  createdAt    DateTime         @default(now()) @map("created_at")

  testRun   TestRun    @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testSteps TestStep[]

  @@index([testRunId])
  @@index([status])
  @@map("test_results")
}

// ============================================================
// TestStep — an individual step within a test result, recording
// the action performed and the expected vs actual outcome.
// ============================================================
model TestStep {
  id           String         @id @default(cuid())
  testResultId String         @map("test_result_id")
  stepNumber   Int            @map("step_number")
  action       String
  expected     String?
  actual       String?
  status       TestStepStatus @default(PENDING)

  testResult  TestResult   @relation(fields: [testResultId], references: [id], onDelete: Cascade)
  screenshots Screenshot[]

  @@index([testResultId])
  @@map("test_steps")
}

// ============================================================
// Screenshot — image captured at a test step, stored in S3.
// ============================================================
model Screenshot {
  id         String   @id @default(cuid())
  testStepId String   @map("test_step_id")
  /// S3 object key for the screenshot image
  s3Key      String   @map("s3_key")
  createdAt  DateTime @default(now()) @map("created_at")

  testStep TestStep @relation(fields: [testStepId], references: [id], onDelete: Cascade)

  @@index([testStepId])
  @@map("screenshots")
}

// ============================================================
// Baseline — reference screenshot used for visual comparison,
// stored in S3, scoped to a project.
// ============================================================
model Baseline {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  /// S3 object key for the baseline image
  s3Key     String   @map("s3_key")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("baselines")
}

// ============================================================
// AgentConfig — JSON configuration for an AI agent scoped to
// an organization, with an active flag to enable/disable it.
// ============================================================
model AgentConfig {
  id         String   @id @default(cuid())
  orgId      String   @map("org_id")
  /// Arbitrary JSON configuration for the agent
  configJson Json     @default("{}") @map("config_json")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("agent_configs")
}

// ============================================================
// AiCreditUsage — ledger entry recording AI credit consumption
// for billing and quota tracking per organization.
// ============================================================
model AiCreditUsage {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  creditsUsed Int      @map("credits_used")
  reason      String
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("ai_credit_usage")
}

// ============================================================
// Notification — user-facing message with a read/unread state.
// ============================================================
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// ============================================================
// Enums
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum TestRunStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  CANCELLED
  TIMEOUT
}

enum TestResultStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
  ERROR
}

enum TestStepStatus {
  PENDING
  PASSED
  FAILED
  SKIPPED
}
