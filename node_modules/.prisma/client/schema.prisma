// This is your Prisma schema file for the SemkiEst platform.
// It defines all core entities for test execution, results tracking, and screenshot storage.
// Learn more about Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organizations ─────────────────────────────────────────────────────────────
// Top-level tenant unit. All resources are scoped to an organization.

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users          User[]
  projects       Project[]
  agentConfigs   AgentConfig[]
  aiCreditUsages AiCreditUsage[]

  @@map("organizations")
}

// ─── Users ─────────────────────────────────────────────────────────────────────
// Platform users belonging to an organization with role-based access.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  orgId        String   @map("org_id")
  role         UserRole @default(MEMBER)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([orgId])
  @@map("users")
}

/// Role assigned to a user within their organization.
enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Projects ──────────────────────────────────────────────────────────────────
// A project groups related test profiles and runs under an organization.

model Project {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  testProfiles TestProfile[]
  testRuns     TestRun[]
  baselines    Baseline[]

  @@index([orgId])
  @@map("projects")
}

// ─── Test Profiles ─────────────────────────────────────────────────────────────
// Named, reusable test configurations that define how tests should be executed.

model TestProfile {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  /// JSON configuration blob (browser options, viewport, retry settings, etc.)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns TestRun[]

  @@index([projectId])
  @@map("test_profiles")
}

// ─── Test Runs ─────────────────────────────────────────────────────────────────
// A single execution of a test profile, recording aggregate run status.

model TestRun {
  id            String        @id @default(cuid())
  testProfileId String        @map("test_profile_id")
  projectId     String        @map("project_id")
  status        TestRunStatus @default(PENDING)
  startedAt     DateTime?     @map("started_at")
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  testProfile TestProfile  @relation(fields: [testProfileId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testResults TestResult[]

  @@index([testProfileId])
  @@index([projectId])
  @@index([status])
  @@map("test_runs")
}

/// Lifecycle status of a test run.
enum TestRunStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  CANCELLED
  TIMED_OUT
}

// ─── Test Results ──────────────────────────────────────────────────────────────
// Individual test case result within a run, capturing pass/fail and error info.

model TestResult {
  id           String           @id @default(cuid())
  testRunId    String           @map("test_run_id")
  testName     String           @map("test_name")
  status       TestResultStatus @default(PENDING)
  errorMessage String?          @map("error_message")
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  testRun   TestRun    @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testSteps TestStep[]

  @@index([testRunId])
  @@index([status])
  @@map("test_results")
}

/// Pass/fail status of an individual test case.
enum TestResultStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
  FLAKY
}

// ─── Test Steps ────────────────────────────────────────────────────────────────
// Granular steps executed within a test case, recording action and assertion outcome.

model TestStep {
  id           String         @id @default(cuid())
  testResultId String         @map("test_result_id")
  stepNumber   Int            @map("step_number")
  /// Description of the action performed (e.g., "click #submit-btn")
  action       String
  /// Expected outcome for assertions
  expected     String?
  /// Actual observed outcome
  actual       String?
  status       TestStepStatus @default(PENDING)

  // Relations
  testResult  TestResult   @relation(fields: [testResultId], references: [id], onDelete: Cascade)
  screenshots Screenshot[]

  @@index([testResultId])
  @@map("test_steps")
}

/// Pass/fail status for a single test step.
enum TestStepStatus {
  PENDING
  PASSED
  FAILED
  SKIPPED
}

// ─── Screenshots ───────────────────────────────────────────────────────────────
// S3-backed screenshots captured at specific test steps for visual debugging.

model Screenshot {
  id         String   @id @default(cuid())
  testStepId String   @map("test_step_id")
  /// S3 object key for retrieving the screenshot image
  s3Key      String   @map("s3_key")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  testStep TestStep @relation(fields: [testStepId], references: [id], onDelete: Cascade)

  @@index([testStepId])
  @@map("screenshots")
}

// ─── Baselines ─────────────────────────────────────────────────────────────────
// Reference screenshot images used for visual regression comparison within a project.

model Baseline {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  /// S3 object key for the baseline reference image
  s3Key     String   @map("s3_key")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("baselines")
}

// ─── Agent Configs ─────────────────────────────────────────────────────────────
// AI agent configuration per organization, with an active flag for hot-swapping configs.

model AgentConfig {
  id         String   @id @default(cuid())
  orgId      String   @map("org_id")
  /// Arbitrary JSON configuration for the AI agent (model params, prompts, tools, etc.)
  configJson Json     @map("config_json")
  active     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, active])
  @@map("agent_configs")
}

// ─── AI Credit Usage ───────────────────────────────────────────────────────────
// Tracks AI token/credit consumption per organization for billing and quotas.

model AiCreditUsage {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  creditsUsed Int      @map("credits_used")
  /// Human-readable description of what caused the credit usage
  reason      String
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
  @@map("ai_credit_usage")
}

// ─── Notifications ─────────────────────────────────────────────────────────────
// In-app notifications delivered to individual users.

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}
