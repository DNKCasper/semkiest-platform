# =============================================================================
# SemkiEst Platform – Environment Variable Template
# =============================================================================
# Copy this file to .env for Docker Compose local development, or to
# .env.local for app-specific local overrides (Next.js, etc.).
#
# DO NOT commit real secrets. This file should only contain safe example values.
# Validation is performed at app startup via Zod schemas in:
#   packages/shared-config/src/env/
# =============================================================================


# -----------------------------------------------------------------------------
# Shared – Node.js Runtime
# -----------------------------------------------------------------------------

# Application environment. Controls logging verbosity, error detail, and
# environment-specific behaviour across all services.
# Values: development | test | staging | production
# Default: development
NODE_ENV=development


# -----------------------------------------------------------------------------
# API Server (apps/api)
# See: packages/shared-config/src/env/api.ts
# -----------------------------------------------------------------------------

# TCP port the API server listens on.
# Default: 3001
PORT=3001

# Hostname the API server binds to. Use 0.0.0.0 to listen on all interfaces
# (required when running inside Docker containers).
# Default: 0.0.0.0
HOST=0.0.0.0

# Secret key used to sign and verify JWT tokens.
# REQUIRED. Must be at least 32 random characters. NEVER commit the real value.
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_use_at_least_32_random_characters_here

# JWT token expiration duration (parsed by the "ms" library).
# Examples: 7d (7 days), 1h (1 hour), 30m (30 minutes)
# Default: 7d
JWT_EXPIRES_IN=7d

# CORS allowed origins, comma-separated.
# REQUIRED. Include every origin that is allowed to call the API.
# Example: http://localhost:3000,https://app.semkiest.com
CORS_ORIGINS=http://localhost:3000

# Log level for the API server logger (pino/winston).
# Values: fatal | error | warn | info | debug | trace | silent
# Default: info
LOG_LEVEL=info

# Optional API key for internal service-to-service authentication.
# When set, internal endpoints require this key in the X-API-Key header.
# Minimum 16 characters. Leave blank to disable internal key auth.
# INTERNAL_API_KEY=


# -----------------------------------------------------------------------------
# Database – PostgreSQL (apps/api, apps/worker)
# See: packages/shared-config/src/env/database.ts
# -----------------------------------------------------------------------------

# Full PostgreSQL connection URL.
# REQUIRED. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Docker Compose default: postgres service on port 5432
DATABASE_URL=postgresql://semkiest:semkiest_password@localhost:5432/semkiest?schema=public

# Direct PostgreSQL connection URL that bypasses PgBouncer connection pooling.
# Required for Prisma migrations. Defaults to DATABASE_URL if not set.
# DIRECT_URL=postgresql://semkiest:semkiest_password@localhost:5432/semkiest?schema=public


# -----------------------------------------------------------------------------
# Redis (apps/api, apps/worker)
# See: packages/shared-config/src/env/redis.ts
# -----------------------------------------------------------------------------

# Redis connection URL.
# REQUIRED. Format: redis://[:password@]HOST[:PORT][/DATABASE]
# With TLS: rediss://[:password@]HOST[:PORT][/DATABASE]
REDIS_URL=redis://localhost:6379

# Key prefix to namespace Redis keys and avoid collisions across environments.
# Default: semkiest
REDIS_KEY_PREFIX=semkiest

# Maximum number of retries when a Redis command fails.
# Default: 3
REDIS_MAX_RETRIES=3


# -----------------------------------------------------------------------------
# S3 / MinIO Object Storage (apps/api)
# See: packages/shared-config/src/env/s3.ts
# -----------------------------------------------------------------------------

# S3 bucket name for storing application files.
# REQUIRED. 3–63 lowercase characters, no spaces.
S3_BUCKET=semkiest-uploads

# AWS region where the S3 bucket resides.
# REQUIRED. For MinIO local development use a dummy value like us-east-1.
S3_REGION=us-east-1

# AWS / MinIO access key ID for authentication.
# REQUIRED.
S3_ACCESS_KEY_ID=minioadmin

# AWS / MinIO secret access key for authentication.
# REQUIRED. NEVER commit the real value.
S3_SECRET_ACCESS_KEY=minioadmin

# Custom S3-compatible endpoint URL (for MinIO or other providers).
# Leave unset to use the default AWS S3 endpoint.
# Example (MinIO via Docker Compose): http://localhost:9000
S3_ENDPOINT=http://localhost:9000

# Whether to force path-style S3 URLs. Required for MinIO.
# Set to true for MinIO, false (or leave blank) for AWS S3.
# Default: false
S3_FORCE_PATH_STYLE=true

# Optional CDN or public base URL for serving S3 assets.
# When set, public asset URLs use this base instead of the S3 bucket URL.
# NEXT_PUBLIC_ASSETS_URL=https://cdn.semkiest.com


# -----------------------------------------------------------------------------
# Web Dashboard – Next.js (apps/web)
# See: packages/shared-config/src/env/web.ts
# -----------------------------------------------------------------------------

# Public-facing base URL of the web application.
# REQUIRED. Used for absolute URL generation in SSR, emails, and redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public-facing base URL of the API server.
# REQUIRED. Used by client-side code for API requests.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal API base URL used only in Next.js Server Components and API Routes.
# Can use Docker internal hostnames when running in containers.
# Example: http://api:3001
# API_INTERNAL_URL=http://localhost:3001

# NextAuth.js secret for signing session tokens.
# Required when using NextAuth. NEVER commit the real value.
# Minimum 32 characters. Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET=CHANGE_ME_use_at_least_32_random_characters_here

# NextAuth.js canonical URL (used in OAuth callbacks).
# Must match NEXT_PUBLIC_APP_URL in most setups.
# NEXTAUTH_URL=http://localhost:3000

# Feature flag: enable debug tooling in non-production environments.
# Default: false
NEXT_PUBLIC_DEBUG=false


# -----------------------------------------------------------------------------
# Slack Integration (apps/api, apps/worker)
# See: packages/shared-config/src/env/slack.ts
# See: packages/integrations/slack
# -----------------------------------------------------------------------------

# Slack Bot OAuth token (xoxb-...).
# Required to send notifications via the Slack Web API.
# Create a Slack app at https://api.slack.com/apps, add the bot scopes:
#   chat:write, channels:read, groups:read
# Then install the app and copy the Bot User OAuth Token here.
# NEVER commit the real value.
# SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack app signing secret for verifying incoming webhook payloads.
# Found in your Slack app settings under "Basic Information > App Credentials".
# Required when using interactive components or slash commands.
# SLACK_SIGNING_SECRET=your-signing-secret-here

# Default Slack channel ID for platform-wide notifications.
# Individual projects override this via per-project channel config in the DB.
# Use the channel ID (e.g. C012AB3CD), not the channel name.
# SLACK_DEFAULT_CHANNEL=C012AB3CD


# -----------------------------------------------------------------------------
# Worker – BullMQ (apps/worker)
# See: packages/shared-config/src/env/worker.ts
# (also inherits DATABASE_URL, REDIS_URL and related vars above)
# -----------------------------------------------------------------------------

# Number of concurrent job processors per worker instance.
# Higher concurrency increases throughput but also memory/CPU usage.
# Default: 5
WORKER_CONCURRENCY=5

# Comma-separated list of queue names this worker instance processes.
# Leave blank to process all queues.
# Example: email,notifications,exports
# WORKER_QUEUES=email,notifications,exports

# Internal API base URL for workers that need to call back into the API.
# Example: http://api:3001
# API_BASE_URL=http://localhost:3001
