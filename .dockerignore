# Dependencies — never copy local node_modules into the image
node_modules
**/node_modules

# Build outputs — start fresh inside Docker
**/dist
**/.next
**/out
**/build
**/*.tsbuildinfo

# Environment and secrets — never bake these into images
.env
.env.*
!.env.example

# Development tooling
**/.turbo
**/coverage
**/.nyc_output

# Version control
.git
.gitignore
.github

# Editor and OS artifacts
.DS_Store
Thumbs.db
**/.idea
**/.vscode
**/*.swp

# CI artifacts
*.sarif
trivy-*.sarif

# Documentation
*.md
!apps/*/README.md
