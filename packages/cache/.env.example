# =============================================================================
# Redis / Cache Service Configuration
# =============================================================================

# Full Redis connection URL.
# Format: redis[s]://[[username][:password]@][host][:port][/db-number]
REDIS_URL=redis://localhost:6379

# Optional: Redis password (can also be embedded in REDIS_URL)
# REDIS_PASSWORD=

# Enable TLS for Redis connections (set to "true" for production with TLS)
# REDIS_TLS=false

# Connection timeout in milliseconds (default: 10000)
# REDIS_CONNECT_TIMEOUT_MS=10000

# Command execution timeout in milliseconds (default: 5000)
# REDIS_COMMAND_TIMEOUT_MS=5000

# Maximum number of reconnection attempts before giving up (default: 10)
# REDIS_MAX_RETRIES=10

# Initial retry delay in milliseconds — doubles on each attempt (default: 100)
# REDIS_RETRY_DELAY_MS=100

# Maximum retry delay cap in milliseconds (default: 30000)
# REDIS_MAX_RETRY_DELAY_MS=30000
