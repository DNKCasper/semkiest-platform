{
  "main": "./dist/index.js",
  "devDependencies": {
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0"
  },
  "description": "Explorer Agent \u2014 authenticated web crawler with session management",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "playwright": "^1.44.0",
    "zod": "^3.23.0",
    "@anthropic-ai/sdk": "^0.36.0"
  },
  "version": "0.0.0",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist coverage",
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist"
  },
  "name": "@semkiest/explorer"
}
