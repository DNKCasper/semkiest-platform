{
  "name": "@semkiest/accessibility-agent",
  "version": "0.0.0",
  "description": "Accessibility testing agent: keyboard nav, contrast, ARIA, and form accessibility",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "axe-core": "^4.9.0",
    "color": "^4.2.3",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/color": "^3.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^@semkiest/(.*)$": "<rootDir>/../$1/src/index.ts"
    }
  }
}
