{
  "references": [
    {
      "path": "../base"
    }
  ],
  "include": [
    "src",
    "src/**/*.ts"
  ],
  "extends": "../../../packages/shared-config/tsconfig/node.json",
  "compilerOptions": {
    "paths": {
      "@semkiest/db": [
        "../../../packages/db/src"
      ],
      "@semkiest/shared-types": [
        "../../../packages/shared-types/src"
      ]
    },
    "sourceMap": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "baseUrl": "."
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}
