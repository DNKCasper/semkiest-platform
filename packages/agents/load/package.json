{
  "main": "./dist/index.js",
  "devDependencies": {
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0"
  },
  "description": "Load testing agent with stress and soak testing capabilities",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "zod": "^3.23.0",
    "@semkiest/agent-base": "workspace:*"
  },
  "version": "0.0.0",
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist coverage",
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist"
  },
  "name": "@semkiest/agents-load"
}
