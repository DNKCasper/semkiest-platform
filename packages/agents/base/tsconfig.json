{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": [
    "src/**/*",
    "src",
    "src/**/*.ts"
  ],
  "extends": "../../shared-config/tsconfig/node.json",
  "compilerOptions": {
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "target": "ES2022",
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "module": "commonjs",
    "isolatedModules": true,
    "declaration": true,
    "lib": [
      "ES2022"
    ],
    "esModuleInterop": true,
    "strictNullChecks": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}
