// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VIEWER
  MEMBER
  MANAGER
  ADMIN
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

/// Represents a tenant organization within the platform
model Organization {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  users    User[]
  projects Project[]

  @@map("organizations")
}

/// Platform user associated with an organization
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String       @map("password_hash")
  role         UserRole     @default(MEMBER)
  orgId        String       @map("org_id")
  organization Organization @relation(fields: [orgId], references: [id])
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

/// A project groups related test profiles and belongs to one organization
model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  orgId        String        @map("org_id")
  organization Organization  @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  profiles TestProfile[]

  @@index([orgId])
  @@index([status])
  @@map("projects")
}

/// A test profile defines configuration for a set of test runs within a project
model TestProfile {
  id        String    @id @default(cuid())
  name      String
  config    Json      @default("{}")
  projectId String    @map("project_id")
  project   Project   @relation(fields: [projectId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([projectId])
  @@map("test_profiles")
}
