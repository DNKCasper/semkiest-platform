{
  "name": "@semkiest/shared-config",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js",
      "require": "./dist/env/index.js"
    },
    "./env/api": {
      "types": "./dist/env/api.d.ts",
      "import": "./dist/env/api.js",
      "require": "./dist/env/api.js"
    },
    "./env/worker": {
      "types": "./dist/env/worker.d.ts",
      "import": "./dist/env/worker.js",
      "require": "./dist/env/worker.js"
    },
    "./env/web": {
      "types": "./dist/env/web.d.ts",
      "import": "./dist/env/web.js",
      "require": "./dist/env/web.js"
    },
    "./env/database": {
      "types": "./dist/env/database.d.ts",
      "import": "./dist/env/database.js",
      "require": "./dist/env/database.js"
    },
    "./env/redis": {
      "types": "./dist/env/redis.d.ts",
      "import": "./dist/env/redis.js",
      "require": "./dist/env/redis.js"
    },
    "./env/s3": {
      "types": "./dist/env/s3.d.ts",
      "import": "./dist/env/s3.js",
      "require": "./dist/env/s3.js"
    },
    "./tsconfig/*": "./tsconfig/*.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/env/index.ts src/env/api.ts src/env/worker.ts src/env/web.ts src/env/database.ts src/env/redis.ts src/env/s3.ts --format cjs,esm --dts --out-dir dist",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
