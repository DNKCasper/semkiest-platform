{
  "extends": "./base.json",
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable"
    ],
    "rootDir": "./src",
    "target": "ES2020",
    "module": "ESNext",
    "outDir": "./dist"
  },
  "display": "React Library"
}
