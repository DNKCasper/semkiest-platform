{
  "display": "Next.js",
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "allowJs": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "ES2022"
    ],
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "isolatedModules": true,
    "target": "ES2017",
    "strict": true,
    "module": "ESNext",
    "skipLibCheck": true,
    "incremental": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "node_modules"
  ],
  "extends": "./base.json"
}
