{
  "extends": "../../packages/shared-config/tsconfig/node.json",
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "paths": {
      "@semkiest/shared-config": [
        "../shared-config/src"
      ]
    },
    "moduleResolution": "node",
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts"
  ]
}
