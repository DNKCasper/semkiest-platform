# =============================================================================
# @semkiest/storage – Environment Variable Template
# =============================================================================
# Copy the relevant variables into your root .env or service-specific .env.local.
# Full variable documentation lives in: packages/shared-config/src/env/s3.ts
# =============================================================================

# Storage provider to use at runtime.
# Values: s3 | minio
# Default: minio (local development)
S3_PROVIDER=minio

# S3 bucket name for storing application files.
# REQUIRED. 3–63 lowercase characters.
S3_BUCKET=semkiest-uploads

# AWS region where the S3 bucket resides.
# For MinIO local development use a dummy value like us-east-1.
S3_REGION=us-east-1

# AWS / MinIO access key ID.
# REQUIRED.
S3_ACCESS_KEY_ID=minioadmin

# AWS / MinIO secret access key.
# REQUIRED. NEVER commit the real value.
S3_SECRET_ACCESS_KEY=minioadmin

# Custom S3-compatible endpoint URL (for MinIO or other providers).
# Leave unset to use the default AWS S3 endpoint.
# Example (MinIO via Docker Compose): http://localhost:9000
S3_ENDPOINT=http://localhost:9000

# Whether to force path-style S3 URLs. Required for MinIO.
# Set to true for MinIO, false (or leave blank) for AWS S3.
S3_FORCE_PATH_STYLE=true
