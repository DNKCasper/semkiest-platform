# Storage Provider Selection
# Options: 's3' (AWS S3) or 'minio' (local MinIO for development)
S3_PROVIDER=minio

# Bucket name for storing test artifacts
S3_BUCKET=semkiest-artifacts

# AWS S3 Configuration (used when S3_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Custom S3-compatible endpoint (required for MinIO, optional for S3)
# MinIO local: http://localhost:9000
# S3 default: leave empty
S3_ENDPOINT=http://localhost:9000

# Force path-style URLs (set to 'true' for MinIO or LocalStack)
S3_FORCE_PATH_STYLE=true

# MinIO-specific configuration
MINIO_USE_SSL=false
MINIO_PORT=9000
