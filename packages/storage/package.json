{
  "name": "@semkiest/storage",
  "version": "0.0.0",
  "description": "S3/MinIO object storage service for SemkiEst platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@semkiest/shared-config": "workspace:*",
    "@semkiest/shared-utils": "workspace:*",
    "minio": "^8.0.0"
  },
  "devDependencies": {
    "@semkiest/shared-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
