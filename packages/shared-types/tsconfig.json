{
  "include": [
    "src/**/*.ts",
    "src"
  ],
  "extends": "@semkiest/shared-config/tsconfig/node",
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "moduleResolution": "node",
    "rootDir": "./src",
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist"
  }
}
