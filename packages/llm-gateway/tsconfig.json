{
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**"
  ],
  "extends": "../shared-config/tsconfig/node.json",
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "target": "ES2022",
    "module": "commonjs",
    "declarationMap": true,
    "outDir": "./dist",
    "isolatedModules": true,
    "rootDir": "./src",
    "declaration": true,
    "lib": [
      "ES2022"
    ],
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
