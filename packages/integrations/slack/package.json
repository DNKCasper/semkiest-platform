{
  "main": "./dist/index.js",
  "private": true,
  "devDependencies": {
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@slack/web-api": "^7.0.0"
  },
  "version": "0.0.0",
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist"
  },
  "name": "@semkiest/slack-integration",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@semkiest/(.*)$": "<rootDir>/../../$1/src/index.ts"
    }
  }
}
