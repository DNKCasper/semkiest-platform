{
  "main": "./dist/index.js",
  "private": true,
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "prisma": "^5.14.0"
  },
  "description": "Database client and Prisma ORM for SemkiEst platform",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "version": "1.0.0",
  "types": "./dist/index.d.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "seed:test": "NODE_ENV=test tsx scripts/seed-test.ts",
    "seed:dev": "NODE_ENV=development tsx scripts/seed-dev.ts",
    "db:push": "prisma db push",
    "typecheck": "tsc --noEmit",
    "seed": "tsx prisma/seed.ts",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "eslint src/",
    "generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "migrate:status": "prisma migrate status",
    "studio": "prisma studio",
    "migrate:reset": "prisma migrate reset --force",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "migrate:dev": "prisma migrate dev",
    "build": "tsc"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "name": "@semkiest/db"
}
