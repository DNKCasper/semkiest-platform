# Database connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/semkiest?schema=public"

# Direct connection URL (used for Prisma migrations, bypasses connection pooling)
# Uncomment and set if using a connection pooler like PgBouncer
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/semkiest?schema=public"

# Node environment (development | test | production)
NODE_ENV="development"
