{
  "include": [
    "src/**/*.ts",
    "src/**/*"
  ],
  "extends": "../../tsconfig.json",
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "scripts"
  ],
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "node",
    "rootDir": "./src",
    "forceConsistentCasingInFileNames": true,
    "target": "ES2022",
    "strict": true,
    "noImplicitReturns": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true
  }
}
