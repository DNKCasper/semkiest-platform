// Prisma schema for SemkiEst platform
// SEM-99: Advanced Test Profile Configuration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Project model (from SEM-63 / SEM-37 dependency)
// ---------------------------------------------------------------------------

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  urls        String[]
  environment String        @default("development")
  status      String        @default("active")
  tags        String[]
  owner       String?
  team        String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  lastRunAt   DateTime?     @map("last_run_at")
  profiles    Profile[]

  @@map("projects")
}

// ---------------------------------------------------------------------------
// Profile model
// SEM-99: test profiles with scheduling, notifications, and auto-triggering
// ---------------------------------------------------------------------------

model Profile {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isTemplate  Boolean  @default(false) @map("is_template")

  /// ProfileTemplateType: smoke-test | full-regression | performance-only | accessibility-audit
  templateType String? @map("template_type")

  /// Array of tag strings for organisation and search
  tags String[]

  /// TestCategoryConfig JSON: { smoke, regression, performance, accessibility }
  testCategories Json @map("test_categories")

  /// Standard cron expression (5 fields), e.g. "0 2 * * *"
  cronExpression String? @map("cron_expression")

  /// NotificationPreferences JSON: { email, slack, webhooks }
  notificationPreferences Json? @map("notification_preferences")

  /// AutoRunTriggers JSON: { onDeploy, onPullRequest, onSchedule, ... }
  autoRunTriggers Json? @map("auto_run_triggers")

  /// Monotonically increasing version counter
  version Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions ProfileVersion[]

  @@index([projectId])
  @@index([isDefault])
  @@index([templateType])
  @@index([tags])
  @@map("profiles")
}

// ---------------------------------------------------------------------------
// ProfileVersion model — immutable history snapshots
// ---------------------------------------------------------------------------

model ProfileVersion {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  version   Int

  /// Full snapshot of the profile's mutable fields at this version
  settings Json

  changedBy  String?  @map("changed_by")
  changeNote String?  @map("change_note")
  createdAt  DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, version])
  @@index([profileId])
  @@map("profile_versions")
}
