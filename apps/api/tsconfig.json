{
  "references": [
    {
      "path": "../../packages/shared"
    },
    {
      "path": "../../packages/database"
    }
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*"
  ],
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@semkiest/slack-integration": [
        "../../packages/integrations/slack/src"
      ],
      "@semkiest/shared-types": [
        "../../packages/shared-types/src"
      ],
      "@semkiest/db": [
        "../../packages/db/src"
      ],
      "@semkiest/shared-utils": [
        "../../packages/shared-utils/src"
      ],
      "@semkiest/shared-config/*": [
        "../../packages/shared-config/src/*"
      ],
      "@semkiest/shared-config": [
        "../../packages/shared-config/src"
      ],
      "@sem/database": [
        "../../packages/database/dist/index.d.ts"
      ],
      "@sem/shared": [
        "../../packages/shared/dist/index.d.ts"
      ]
    },
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "."
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
