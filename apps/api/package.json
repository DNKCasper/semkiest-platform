{
  "main": "./dist/server.js",
  "private": true,
  "devDependencies": {
    "eslint": "^8.57.0",
    "ts-jest": "^29.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.5.0",
    "@types/supertest": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "supertest": "^7.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@types/express": "^4.17.21",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "ts-node-dev": "^2.0.0"
  },
  "dependencies": {
    "@semkiest/shared-utils": "workspace:*",
    "cron-parser": "^4.9.0",
    "@sem/database": "workspace:*",
    "exceljs": "^4.4.0",
    "express": "^4.19.0",
    "@semkiest/shared-types": "workspace:*",
    "@semkiest/db": "workspace:*",
    "cors": "^2.8.5",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "ioredis": "^5.3.2",
    "zod": "^3.23.0",
    "@semkiest/slack-integration": "workspace:*",
    "helmet": "^8.1.0",
    "@sentry/node": "^8.0.0",
    "@semkiest/jira-integration": "workspace:*",
    "fastify": "^4.28.0",
    "@slack/web-api": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "@sem/shared": "workspace:*",
    "rate-limiter-flexible": "^5.0.0",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "@semkiest/shared-config": "workspace:*",
    "@prisma/client": "^5.14.0"
  },
  "version": "1.0.0",
  "scripts": {
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "test:coverage": "jest --coverage --passWithNoTests",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc"
  },
  "name": "@sem/api",
  "jest": {
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "roots": ["<rootDir>/src"],
    "moduleNameMapper": {
      "@semkiest/shared-types": "<rootDir>/../../packages/shared-types/src",
      "@semkiest/db": "<rootDir>/../../packages/db/src",
      "@semkiest/shared-utils": "<rootDir>/../../packages/shared-utils/src",
      "@semkiest/shared-config": "<rootDir>/../../packages/shared-config/src",
      "@sem/database": "<rootDir>/../../packages/database/src/index.ts",
      "@sem/shared": "<rootDir>/../../packages/shared/src/index.ts"
    },
    "preset": "ts-jest",
    "collectCoverageFrom": ["src/**/*.ts", "!src/server.ts"],
    "testEnvironment": "node"
  }
}
