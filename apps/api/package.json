{
  "name": "@semkiest/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@semkiest/db": "workspace:*",
    "@semkiest/shared-config": "workspace:*",
    "@semkiest/shared-types": "workspace:*",
    "@semkiest/shared-utils": "workspace:*",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "express": "^4.19.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "moduleNameMapper": {
      "@semkiest/shared-types": "<rootDir>/../../packages/shared-types/src",
      "@semkiest/shared-utils": "<rootDir>/../../packages/shared-utils/src",
      "@semkiest/shared-config": "<rootDir>/../../packages/shared-config/src",
      "@semkiest/db": "<rootDir>/../../packages/db/src"
    }
  }
}
